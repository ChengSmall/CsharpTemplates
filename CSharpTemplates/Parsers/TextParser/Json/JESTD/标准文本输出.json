{
  /*
    json标准文本输出（JSON expandable standard text output），是在json语法框架下定制的一套输出文本的编写标准
    每一个json值都可作为文本输出，符合标准则输出标准，不符合标准则同样输出文本，但输出内容不做定义
    复合对象下，type值可进行扩展
  */

  "纯文本": "采用字符串json对象的纯文本，输出内容与字符串一致，支持转义字符\r\n\t\b\u0000\\",

  "使用数字转文本": 3.1415, // 用数值json对象，可自动转化为对应文本

  "复合对象": {
    // 用 {} 表示为复合对象，每个复合对象都有一个 type 参数表示输出类型
    "type": "输出类型", //必选项
    "value": "文本输出" //有时是可选项，有时是必选项，按type内的值做语义区分
    // type参数的类型如果不是基本标准内的参数，也没有可用的扩展标准，则输出没有标准定义
    // 复合对象除了 type value 外，也可以扩展其它自定义key项
  },

  "定义样式": {
    // 复合对象，定制文本的颜色和样式
    "type": "styles",
    "value": "标准文本输出", // 必选
    "color": "FFFFFF", // 这里写文本颜色，颜色格式为十六进制的 RRGGBB；（可选）
    "underline": true, // 是否有下划线（可选）
    "italic": true, // 文本是否为斜体（可选）
    "strikethrough": true // 文本是否加删除线（可选）
    // 如果实现的运行时没有对应的样式功能，则忽略无法实现的功能，仅使用可用的样式或仅输出 value 内的标准文本
  },

  "连接输出文本集合": [
    // 采用json集合[]来连接前后文本输出，从第一个输出文本拼接到最后一个，每一个都可嵌套标准文本输出
    "第一段输出文本\n",
    {
      "type": "styles",
      "text": "第二段文本",
      "color": "FF8020"
    },
    [ "第三段文本", "标准文本输出", "..." ]
  ],

  "用type定义连续输出的文本集合": {
    // type使用list作为类型参数，value的内容与直接写 [] 没有区别
    "type": "list",
    "value": [ "text1", "text2" ]
  },

  "复合对象使用纯文本": {
    // 用text输出纯文本，value只能是纯文本输出
    "type": "text",
    "value": "json格式纯文本"
  }

}